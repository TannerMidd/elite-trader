{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "useDefineForClassFields": true
  },
  "include": ["ui/src/**/*.js", "ui/src/**/*.d.ts"],
  "exclude": ["ui/src/**/*.test.js"]
}
