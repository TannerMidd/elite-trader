# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# Editors / OS
.vscode/
.idea/
Thumbs.db

# Local runtime leftovers
*.log
*.pid

# Local market database + Spansh dump (multi-GB, machine-local)
/data/
# This root-anchored rule deliberately does not match ui/src/data: the
# frontend's small static ESM datasets are versioned application source.
# The small, release-built engineering reference is application data, not a
# commander database.  It must be versioned and bundled into the executable.
!elite/data/
elite/data/*
!elite/data/engineering_catalog.json.gz

# PyInstaller build output
build/
dist/
*.spec

# Demo-recording browser profiles (Playwright/Edge scratch state)
showcase/

# Frontend development tooling
node_modules/
coverage/
playwright-report/
test-results/
.vitest/
*.tsbuildinfo
